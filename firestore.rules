rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Test Connection
    match /test/connection {
      allow read: if true;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for User validation
    function isValidUser(data) {
      return data.keys().hasAll(['points', 'warnings', 'banned']) 
             && data.keys().size() == 3
             && data.points is int && data.points >= 0
             && data.warnings is int && data.warnings >= 0
             && data.banned is bool;
    }

    // Helper for Group validation
    function isValidGroup(data) {
      return data.keys().hasAll(['enabled'])
             && data.keys().size() == 1
             && data.enabled is bool;
    }

    // Helper for Setting validation
    function isValidSetting(data) {
      return data.keys().hasAny(['ownerNumber'])
             && data.ownerNumber is string && data.ownerNumber.size() <= 20;
    }

    // Phase 4: Match Blocks
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
